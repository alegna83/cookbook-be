@startuml
title Dataflow - PII and Data Retention

package "Stays4Pilgrims System" {
  package "Stays4Pilgrims Frontend (Flutter/Web)" as Frontend {
    queue "User Input\nCredentials, Profile, Reviews" as FE_INPUT
  }

  package "Stays4Pilgrims Backend (NestJS)" as Backend {
    component "Auth Service\n[Hash passwords - bcrypt]" as AUTH
    component "Accounts Service\n[Email, Name, Password]" as ACC
    component "Accommodations Service\n[Address, Contact Info]" as ACCOMMODATIONS
    component "Comments Service\n[Rating, Text]" as COMMENTS
    component "Gallery Service\n[Image URLs, metadata]" as GALLERY
    component "Contact Service\n[Name, Email, Phone, Message]" as CONTACT
  }

  database "PostgreSQL" as DB {
    entity "accounts\n(id, email, password_hash,\nname, phone, isEmailVerified,\ncreatedAt)" as TBL_ACC
    entity "accommodations\n(id, accomodation_name, address,\nphone, email, website,\naccount_id)" as TBL_ACCOMMODATIONS
    entity "comments\n(id, text, rating,\naccountId, accomodationId,\nstatus, createdAt)" as TBL_COMMENTS
    entity "gallery_photos\n(id, url, accountId,\naccomodationId, status)" as TBL_GALLERY
  }

  package "External Services" {
    queue "Email Service\n[Verification, Contact, Moderation Emails]" as EMAIL_SVC
    queue "Storage (S3/Local)\n[Image Binary Data]" as STORAGE
  }

  package "Backups & Archive" {
    database "Daily Backup (encrypted)\n24-month retention" as BACKUP
    queue "Audit Logs\n(indefinite retention)" as AUDIT
  }
}

FE_INPUT --> AUTH: credentials
FE_INPUT --> CONTACT: contact form payload
AUTH --> TBL_ACC: hash + store
ACC --> TBL_ACC: name, email, phone
ACCOMMODATIONS --> TBL_ACCOMMODATIONS: address, contact
COMMENTS --> TBL_COMMENTS: text, rating
GALLERY --> TBL_GALLERY: URLs
CONTACT --> EMAIL_SVC: forward contact request
EMAIL_SVC <--> ACC: verification flows
EMAIL_SVC <--> COMMENTS: moderation decision emails
EMAIL_SVC <--> ACCOMMODATIONS: moderation decision emails
STORAGE <-- GALLERY: image uploads
DB --> BACKUP: nightly snapshot
DB --> AUDIT: all queries logged

note right of TBL_ACC
  PII: email, phone, password_hash
  Retention: Active accounts - lifetime
  Deleted accounts - anonymized after 30 days
end note

note right of TBL_ACCOMMODATIONS
  PII: phone, email, address
  Retention: While accommodation is active
  Archived accommodations - retained 12 months
end note

note right of EMAIL_SVC
  Verification: 24h transient tokens
  Contact and moderation emails include
  user identity, accommodation name and optional reason
  Logs: Deleted after completion
end note

note right of STORAGE
  Images: CDN cache 7 days,
  Archive: indefinite
end note

@enduml
