@startuml
title Stays4Pilgrims - Database Entity-Relationship Diagram

entity "Account (accounts)" as account {
  * id : INT <<PK>>
  * email : VARCHAR(255) <<UQ>>
  * name : VARCHAR(255)
  * user_type : ENUM (normal, admin)
  * is_email_verified : BOOLEAN
}

entity "Accomodation" as Accomodation {
  * id : INT <<PK>>
  * Accomodation_name : VARCHAR(255)
  * status : ENUM (pending, approved, rejected)
  * approved_at : TIMESTAMP
  * rejection_reason : VARCHAR(500)
  account_id : INT <<FK>>
  Accomodation_category_id : INT <<FK>>
  camino_id : INT <<FK>>
  stage_id : INT <<FK>>
}

entity "AccomodationCategory (Accomodation_categories)" as Accomodation_category {
  * id : INT <<PK>>
  * name : VARCHAR(100) <<UQ>>
}

entity "Comment (comments)" as comment {
  * id : INT <<PK>>
  * rating : INT (1-5)
  * comment : TEXT
  * status : ENUM (pending, approved, rejected)
  * approved_at : TIMESTAMP
  * rejection_reason : VARCHAR(500)
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  account_id : INT <<FK>>
  Accomodation_id : INT <<FK>>
}

entity "GalleryPhoto (gallery_photos)" as gallery_photo {
  * id : INT <<PK>>
  * photo_url : TEXT
  * status : ENUM (pending, approved, rejected)
  * approved_at : TIMESTAMP
  * rejection_reason : VARCHAR(500)
  * created_at : TIMESTAMP
  account_id : INT <<FK>>
  Accomodation_id : INT <<FK>>
}

entity "Favorite (favorites)" as favorite {
  * id : INT <<PK>>
  * created_at : TIMESTAMP
  account_id : INT <<FK>>
  Accomodation_id : INT <<FK>>
}

entity "AccomodationPrice" as Accomodation_price {
  * id : INT <<PK>>
  * description : VARCHAR
  * price : DECIMAL(10,2)
  Accomodation_id : INT <<FK>>
}

entity "AccomodationRemovalRequest" as Accomodation_removal_request {
  * id : INT <<PK>>
  * Accomodation_name : VARCHAR(255)
  * requester_name : VARCHAR(255)
  * requester_email : VARCHAR(255)
  * reason : TEXT
  * status : ENUM (pending, approved, rejected)
  * created_at : TIMESTAMP
  * reviewed_at : TIMESTAMP
  * rejection_reason : VARCHAR(500)
  account_id : INT <<FK>>
  Accomodation_id : INT <<FK>>
}

entity "AccomodationEditRequest" as Accomodation_edit_request {
  * id : INT <<PK>>
  * requester_name : VARCHAR(255)
  * requester_email : VARCHAR(255)
  * payload : JSON
  * status : ENUM (pending, approved, rejected)
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  * reviewed_at : TIMESTAMP
  * rejection_reason : VARCHAR(500)
  account_id : INT <<FK>>
  Accomodation_id : INT <<FK>>
}

entity "Camino (caminos)" as camino {
  * id : INT <<PK>>
  * name : VARCHAR(100) <<UQ>>
}

entity "Stage (stages)" as stage {
  * id : INT <<PK>>
  * name : VARCHAR(100)
  camino_id : INT <<FK>>
}

' Relationships
account ||--o{ Accomodation : "owns"
account ||--o{ comment : "writes"
account ||--o{ gallery_photo : "uploads"
account ||--o{ favorite : "marks"
account ||--o{ Accomodation_removal_request : "requests"
account ||--o{ Accomodation_edit_request : "requests"

Accomodation_category ||--o{ Accomodation : "categorizes"
Accomodation ||--o{ comment : "receives"
Accomodation ||--o{ gallery_photo : "contains"
Accomodation ||--o{ favorite : "marked_in"
Accomodation ||--o{ Accomodation_price : "has_prices"
Accomodation ||--o{ Accomodation_removal_request : "subject_of"
Accomodation ||--o{ Accomodation_edit_request : "subject_of"
Accomodation }o--|| camino : "located_in"
Accomodation }o--|| stage : "mapped_to"

camino ||--o{ stage : "contains"

@enduml

