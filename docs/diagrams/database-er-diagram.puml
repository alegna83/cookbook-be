@startuml
title Stays4Pilgrims - Database Entity-Relationship Diagram

entity "account" as account {
  * id : INT <<PK>>
  * email : VARCHAR(255) <<UQ>>
  * password_hash : VARCHAR(255)
  * name : VARCHAR(255)
  * pilgrim_reason : VARCHAR(100)
  * pilgrim_reason_other : TEXT
  * avatar : TEXT (URL)
  * email_verified : BOOLEAN
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  * deleted_at : TIMESTAMP (soft delete)
}

entity "place (accommodation)" as place {
  * id : INT <<PK>>
  * name : VARCHAR(255)
  * description : TEXT
  * latitude : DECIMAL(9,6)
  * longitude : DECIMAL(9,6)
  * address : VARCHAR(255)
  * city : VARCHAR(100)
  * postal_code : VARCHAR(20)
  * phone : VARCHAR(20)
  * email : VARCHAR(255)
  * website : VARCHAR(255)
  * capacity : INT
  * price_per_night : DECIMAL(10,2)
  * approved : BOOLEAN
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  account_id : INT <<FK>>
  place_category_id : INT <<FK>>
}

entity "place_category (accommodation_category)" as place_category {
  * id : INT <<PK>>
  * name : VARCHAR(100) <<UQ>>
  * description : TEXT
  * icon : VARCHAR(255)
  * color : VARCHAR(7)
}

entity "place_service" as place_service {
  * id : INT <<PK>>
  * name : VARCHAR(100)
  * description : TEXT
  * category : VARCHAR(50)
}

entity "place_has_service" as place_has_service {
  * id : INT <<PK>>
  place_id : INT <<FK>>
  place_service_id : INT <<FK>>
}

entity "comment" as comment {
  * id : INT <<PK>>
  * rating : INT (1-5)
  * text : TEXT
  * approved : BOOLEAN
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  account_id : INT <<FK>>
  place_id : INT <<FK>>
}

entity "gallery_photo" as gallery_photo {
  * id : INT <<PK>>
  * url : TEXT (Cloudinary URL)
  * alt_text : VARCHAR(255)
  * approved : BOOLEAN
  * rejection_reason : TEXT
  * created_at : TIMESTAMP
  account_id : INT <<FK>>
  place_id : INT <<FK>>
}

entity "favorite" as favorite {
  * id : INT <<PK>>
  * created_at : TIMESTAMP
  account_id : INT <<FK>>
  place_id : INT <<FK>>
}

entity "place_removal_request" as place_removal_request {
  * id : INT <<PK>>
  * reason : TEXT
  * status : ENUM (pending, approved, rejected)
  * created_at : TIMESTAMP
  * reviewed_at : TIMESTAMP
  account_id : INT <<FK>>
  place_id : INT <<FK>>
}

entity "camino" as camino {
  * id : INT <<PK>>
  * name : VARCHAR(100) <<UQ>>
  * description : TEXT
  * difficulty : ENUM (easy, moderate, hard)
  * distance_km : DECIMAL(8,2)
  * days : INT
  * start_location : VARCHAR(100)
  * end_location : VARCHAR(100)
  * start_latitude : DECIMAL(9,6)
  * start_longitude : DECIMAL(9,6)
}

entity "stage" as stage {
  * id : INT <<PK>>
  * name : VARCHAR(100)
  * distance_km : DECIMAL(8,2)
  * day_number : INT
  * start_location : VARCHAR(100)
  * end_location : VARCHAR(100)
  * description : TEXT
  camino_id : INT <<FK>>
}

entity "place_price" as place_price {
  * id : INT <<PK>>
  * price : DECIMAL(10,2)
  * currency : VARCHAR(3)
  * season : ENUM (low, medium, high)
  * created_at : TIMESTAMP
  place_id : INT <<FK>>
}

entity "statistics_caminos" as statistics_caminos {
  * id : INT <<PK>>
  * camino_id : INT <<FK>>
  * count_pilgrims : INT
  * average_rating : DECIMAL(3,2)
  * count_accommodations : INT
}

' Relationships
account ||--o{ place : "owns"
account ||--o{ comment : "writes"
account ||--o{ gallery_photo : "uploads"
account ||--o{ favorite : "marks"
account ||--o{ place_removal_request : "requests"

place_category ||--o{ place : "categorizes"
place ||--o{ comment : "receives"
place ||--o{ gallery_photo : "contains"
place ||--o{ favorite : "marked_in"
place ||--o{ place_removal_request : "subject_of"
place ||--o{ place_price : "has"
place }o--|| camino : "located_in"

place_service ||--o{ place_has_service : "listed_in"
place ||--o{ place_has_service : "offers"

camino ||--o{ stage : "contains"
camino ||--o{ statistics_caminos : "tracked_in"

@enduml
