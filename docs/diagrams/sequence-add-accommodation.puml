@startuml
title Add Accomodation (create) sequence
actor User
participant "Stays4Pilgrims Frontend" as FE
participant "Stays4Pilgrims Backend - AccomodationsController" as API
participant "AccomodationsService" as SVC
participant "ContentModerationService" as MOD
participant "CategoryRepo / DB" as CATDB
participant "AccomodationRepo / DB" as ADB
participant "GalleryPhotoRepo / DB" as GDB

User -> FE: Fill "Add Accomodation" form (data + main_photo + gallery_photos)
FE -> API: POST /Accomodations/handle { action: 'create', payload: CreateAccomodationDto }
activate API
API -> SVC: create(CreateAccomodationDto)
activate SVC
alt gallery_photos present
  SVC -> MOD: moderateImageUrls(galleryPhotoUrls)
  activate MOD
  MOD --> SVC: moderation result (allow/reject)
  deactivate MOD
  alt moderation rejected
    SVC --> API: throw BadRequest (images rejected)
    deactivate SVC
    API --> FE: 400 Bad Request
    deactivate API
    return
  end
end

alt Accomodation_category provided
  SVC -> CATDB: find category by id or name
  activate CATDB
  CATDB --> SVC: category or not found
  deactivate CATDB
end

SVC -> ADB: save new Accomodation (main_photo normalized)
activate ADB
ADB --> SVC: saved Accomodation id
deactivate ADB

alt gallery_photos present
  SVC -> GDB: save gallery photos as status='pending'
  activate GDB
  GDB --> SVC: saved gallery entries
  deactivate GDB
end

SVC -> ADB: findOne with relations (gallery_photos, category, prices...)
activate ADB
ADB --> SVC: full saved entity
deactivate ADB

SVC --> API: return created AccomodationDto
deactivate SVC
API --> FE: 200 OK {AccomodationDto}
deactivate API

note over FE,GDB: Gallery photos are created pending moderation; approved later by admin or moderation pipeline

@enduml

